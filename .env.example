# Copy to .env and fill in real values. .env is gitignored.
DATABASE_URL=postgresql://localhost:5432/contentos_dev
ANTHROPIC_API_KEY=
GENERATION_MODEL=claude-opus-4-8

# --- Content Repurpose mode ---
# Deepgram STT key (nova-3) for webinar transcription.
DEEPGRAM_API_KEY=

# Object storage for the source video + cut clips. Provider-agnostic (S3 SDK).
# For Cloudflare R2: set S3_ENDPOINT to the R2 S3 API endpoint and leave
# S3_REGION as "auto"; create an R2 API token for the access key + secret.
#   S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# For AWS S3: leave S3_ENDPOINT unset and set S3_REGION to your bucket's region.
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_REGION=auto

# --- Google OAuth (Auth.js) ---
# Generate AUTH_SECRET with: openssl rand -base64 33
AUTH_SECRET=
# OAuth 2.0 Client ID + secret from Google Cloud Console (gtm-engineering project).
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
